import React, { useState, useEffect, useRef, useCallback } from 'react';
import { orchestrateAPI } from '../services/api';

const MODES = [
  { id: 'single', label: 'Single', icon: '◈', desc: 'One agent responds' },
  { id: 'race', label: 'Race', icon: '⚡', desc: 'All agents in parallel' },
  { id: 'debate', label: 'Debate', icon: '⚔', desc: 'Agents argue positions' },
  { id: 'chain', label: 'Chain', icon: '⛓', desc: 'Output feeds next agent' },
];

const ProviderColors = {
  openai: '#10a37f', anthropic: '#d4702f', gemini: '#4285f4',
  mistral: '#ff7000', groq: '#f55036', cohere: '#4ade80',
};

function ResponseCard({ result, isWinner }) {
  const [expanded, setExpanded] = useState(true);

  if (!result) return null;

  return (
    <div className={`response-card ${isWinner ? 'winner' : ''} ${result.success === false ? 'error' : ''}`}>
      <div className="response-card-header">
        <div className="response-card-meta">
          <span className={`provider-badge ${result.provider}`}>{result.provider}</span>
          {result.agentName && result.agentName !== result.provider && (
            <span style={{ fontSize: 13, fontWeight: 500 }}>{result.agentName}</span>
          )}
          <span style={{ fontSize: 12, color: 'var(--text-muted)', fontFamily: 'var(--font-mono)' }}>
            {result.model?.split('-').slice(0, 3).join('-')}
          </span>
          {isWinner && <span className="badge badge-green">★ Best</span>}
        </div>
        <div className="response-card-stats">
          {result.latencyMs && <span>{(result.latencyMs / 1000).toFixed(1)}s</span>}
          {result.tokensUsed && <span>{result.tokensUsed} tok</span>}
          <button
            className="btn btn-ghost btn-icon"
            style={{ padding: '2px 6px', fontSize: 12 }}
            onClick={() => setExpanded(!expanded)}
          >
            {expanded ? '▲' : '▼'}
          </button>
        </div>
      </div>
      {expanded && (
        <div className="response-card-body">
          {result.success === false ? (
            <span style={{ color: 'var(--accent-red)' }}>⚠ Error: {result.error}</span>
          ) : (
            result.content
          )}
        </div>
      )}
    </div>
  );
}

function JudgementPanel({ judgement }) {
  if (!judgement) return null;

  const raw = judgement.rawContent || '';
  let parsed = null;
  try {
    const j = judgement.judgement;
    if (typeof j === 'object') parsed = j;
  } catch {}

  return (
    <div style={{
      background: 'rgba(168,85,247,0.08)',
      border: '1px solid rgba(168,85,247,0.3)',
      borderRadius: 'var(--radius-lg)',
      padding: 16,
      marginTop: 16,
    }}>
      <div style={{ fontSize: 13, fontWeight: 600, color: '#c084fc', marginBottom: 10 }}>
        🧑‍⚖️ AI Judge Analysis ({judgement.provider})
      </div>
      {parsed ? (
        <div style={{ display: 'flex', flexDirection: 'column', gap: 8 }}>
          {parsed.winner && <div className="text-sm"><strong>Winner:</strong> {parsed.winner}</div>}
          {parsed.key_differences && <div className="text-sm"><strong>Key differences:</strong> {parsed.key_differences}</div>}
          {parsed.best_response_synthesis && (
            <div className="text-sm"><strong>Synthesis:</strong> {parsed.best_response_synthesis}</div>
          )}
        </div>
      ) : (
        <div style={{ fontSize: 13, lineHeight: 1.7, whiteSpace: 'pre-wrap' }}>{raw}</div>
      )}
    </div>
  );
}

export default function OrchestratePanel({ agents, tabType, toast }) {
  const [prompt, setPrompt] = useState('');
  const [mode, setMode] = useState('single');
  const [selectedAgents, setSelectedAgents] = useState([]);
  const [messages, setMessages] = useState([]);
  const [loading, setLoading] = useState(false);
  const [withJudge, setWithJudge] = useState(false);
  const messagesEndRef = useRef(null);
  const textareaRef = useRef(null);

  useEffect(() => {
    if (agents.length > 0 && selectedAgents.length === 0) {
      setSelectedAgents([agents[0].id]);
    }
  }, [agents]);

  useEffect(() => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages]);

  const toggleAgent = (id) => {
    setSelectedAgents((prev) =>
      prev.includes(id) ? prev.filter((a) => a !== id) : [...prev, id]
    );
  };

  const handleSubmit = async () => {
    if (!prompt.trim() || loading) return;
    if (selectedAgents.length === 0) {
      toast.error('Select at least one agent');
      return;
    }

    const userMessage = { role: 'user', content: prompt.trim(), timestamp: new Date() };
    setMessages((prev) => [...prev, userMessage]);
    const currentPrompt = prompt.trim();
    setPrompt('');
    setLoading(true);

    try {
      const res = await orchestrateAPI.run({
        prompt: currentPrompt,
        agents: selectedAgents,
        mode,
        options: {
          judge: withJudge && selectedAgents.length > 1,
          tabType,
          saveConversation: true,
        },
      });

      const aiMessage = {
        role: 'assistant',
        timestamp: new Date(),
        mode: res.data.mode,
        results: res.data.results,
        judgement: res.data.judgement,
        totalTimeMs: res.data.totalTimeMs,
      };

      setMessages((prev) => [...prev, aiMessage]);
    } catch (err) {
      toast.error(err.response?.data?.error || 'Orchestration failed');
      setMessages((prev) => prev.slice(0, -1)); // Remove user message on error
    } finally {
      setLoading(false);
    }
  };

  const handleKeyDown = (e) => {
    if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) {
      handleSubmit();
    }
  };

  const clearChat = () => {
    if (messages.length === 0) return;
    if (window.confirm('Clear conversation?')) setMessages([]);
  };

  const getTabPlaceholder = () => {
    switch (tabType) {
      case 'research': return 'Ask a research question... agents will analyze from multiple perspectives';
      case 'code': return 'Describe code you need... agents will generate and compare implementations';
      case 'chat': return 'Start a conversation... use Race mode to compare agent responses';
      default: return 'Enter your prompt...';
    }
  };

  return (
    <div className="chat-layout" style={{ height: 'calc(100vh - 130px)' }}>
      {/* Agent Selector */}
      <div style={{ display: 'flex', alignItems: 'center', gap: 10, flexWrap: 'wrap', flexShrink: 0 }}>
        <span style={{ fontSize: 12, color: 'var(--text-muted)', fontFamily: 'var(--font-mono)', whiteSpace: 'nowrap' }}>AGENTS:</span>
        <div className="agent-selector">
          {agents.length === 0 ? (
            <span className="text-sm text-muted">No agents configured. Go to Agents tab to create some.</span>
          ) : (
            agents.filter((a) => a.is_active !== false).map((agent) => (
              <div
                key={agent.id}
                className={`agent-chip ${selectedAgents.includes(agent.id) ? 'selected' : ''}`}
                onClick={() => toggleAgent(agent.id)}
              >
                <span
                  className="agent-chip-dot"
                  style={{ background: ProviderColors[agent.provider] || 'var(--text-muted)' }}
                />
                {agent.name}
                <span style={{ fontSize: 10, opacity: 0.6 }}>({agent.provider})</span>
              </div>
            ))
          )}
        </div>
        <button className="btn btn-ghost btn-sm btn-icon" onClick={clearChat} title="Clear chat">🗑</button>
      </div>

      {/* Messages */}
      <div className="chat-messages">
        {messages.length === 0 && (
          <div className="empty-state" style={{ padding: '60px 24px' }}>
            <div className="empty-icon">
              {tabType === 'research' ? '🔬' : tabType === 'code' ? '💻' : '💬'}
            </div>
            <div className="empty-title">
              {tabType === 'research' ? 'Multi-Agent Research' : tabType === 'code' ? 'Code Generation' : 'AI Chat'}
            </div>
            <div className="empty-desc">
              Select agents above and choose a mode, then send your first message
            </div>
          </div>
        )}

        {messages.map((msg, i) => (
          <div key={i}>
            {msg.role === 'user' ? (
              <div className="message user">
                <div className="message-avatar">U</div>
                <div className="message-content">
                  <div className="message-bubble">{msg.content}</div>
                  <div className="message-meta">
                    <span className="message-time">{new Date(msg.timestamp).toLocaleTimeString()}</span>
                  </div>
                </div>
              </div>
            ) : (
              <div className="message assistant">
                <div className="message-avatar">🤖</div>
                <div className="message-content" style={{ width: '100%' }}>
                  <div className="message-meta" style={{ marginBottom: 8 }}>
                    <span className={`badge ${msg.mode === 'race' ? 'badge-amber' : msg.mode === 'debate' ? 'badge-purple' : 'badge-blue'}`}>
                      {msg.mode}
                    </span>
                    <span className="message-time">
                      {new Date(msg.timestamp).toLocaleTimeString()} · {(msg.totalTimeMs / 1000).toFixed(1)}s total
                    </span>
                  </div>

                  {/* Results grid */}
                  <div className={`response-grid ${msg.mode === 'race' ? 'race-mode' : ''}`}>
                    {msg.mode === 'debate' ? (
                      // Debate mode - show rounds
                      (msg.results || []).map((round, ri) => (
                        <div key={ri}>
                          <div style={{ fontSize: 12, fontFamily: 'var(--font-mono)', color: 'var(--text-muted)', marginBottom: 8 }}>
                            ROUND {ri + 1}
                          </div>
                          {round.map((r, j) => (
                            <ResponseCard key={j} result={r} />
                          ))}
                        </div>
                      ))
                    ) : (
                      (msg.results || []).map((result, j) => (
                        <ResponseCard key={j} result={result} />
                      ))
                    )}
                  </div>

                  {msg.judgement && <JudgementPanel judgement={msg.judgement} />}
                </div>
              </div>
            )}
          </div>
        ))}

        {loading && (
          <div className="message assistant">
            <div className="message-avatar">🤖</div>
            <div className="message-content">
              <div className="message-bubble" style={{ display: 'inline-flex', gap: 8, alignItems: 'center' }}>
                <div className="loading-dots"><span /><span /><span /></div>
                <span className="text-muted text-sm">
                  {mode === 'race' ? `Racing ${selectedAgents.length} agents...` :
                   mode === 'debate' ? 'Agents debating...' :
                   mode === 'chain' ? 'Chaining agents...' : 'Thinking...'}
                </span>
              </div>
            </div>
          </div>
        )}
        <div ref={messagesEndRef} />
      </div>

      {/* Prompt Input */}
      <div className="prompt-area" style={{ flexShrink: 0 }}>
        <div className="prompt-toolbar">
          <span style={{ fontSize: 11, color: 'var(--text-muted)', fontFamily: 'var(--font-mono)' }}>MODE:</span>
          {MODES.map((m) => (
            <button
              key={m.id}
              className={`btn btn-sm ${mode === m.id ? 'btn-primary' : 'btn-ghost'}`}
              style={{ fontSize: 12, padding: '4px 10px' }}
              onClick={() => setMode(m.id)}
              title={m.desc}
            >
              {m.icon} {m.label}
            </button>
          ))}
          <div style={{ flex: 1 }} />
          {selectedAgents.length > 1 && (
            <label style={{ display: 'flex', alignItems: 'center', gap: 6, fontSize: 12, color: 'var(--text-secondary)', cursor: 'pointer' }}>
              <input
                type="checkbox"
                checked={withJudge}
                onChange={(e) => setWithJudge(e.target.checked)}
                style={{ accentColor: 'var(--accent-primary)' }}
              />
              AI Judge
            </label>
          )}
        </div>

        <textarea
          ref={textareaRef}
          className="prompt-textarea"
          placeholder={getTabPlaceholder()}
          value={prompt}
          onChange={(e) => setPrompt(e.target.value)}
          onKeyDown={handleKeyDown}
          disabled={loading}
        />

        <div className="prompt-footer">
          <span className="prompt-hint">⌘+Enter to send · {selectedAgents.length} agent(s) selected</span>
          <button
            className="btn btn-primary btn-sm"
            onClick={handleSubmit}
            disabled={loading || !prompt.trim() || selectedAgents.length === 0}
          >
            {loading ? <span className="loading-dots"><span /><span /><span /></span> : '↑ Send'}
          </button>
        </div>
      </div>
    </div>
  );
}
